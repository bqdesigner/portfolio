{
  "cleanUrls": true,
  "redirects": [
    {
      "source": "/design-to-code/:project",
      "destination": "/design-to-code/:project/",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/blog",
      "destination": "https://portifolio-with-ia-blog.vercel.app/blog"
    },
    {
      "source": "/blog/:path*",
      "destination": "https://portifolio-with-ia-blog.vercel.app/blog/:path*"
    }
  ]
}
